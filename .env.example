# PostHog Analytics (never commit real keys)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# Next.js client exposure (use these in production deployments)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Microsoft Clarity (session recordings and heatmaps — never commit real project IDs)
NEXT_PUBLIC_CLARITY_PROJECT_ID=
VITE_CLARITY_PROJECT_ID=

# Application environment (development | replica | qa | uat | pre-production | production)
# Optional — Vercel preview deployments auto-detect via VERCEL_ENV when unset.
NEXT_PUBLIC_APP_ENV=development

# Optional API base URL
NEXT_PUBLIC_API_BASE_URL=

